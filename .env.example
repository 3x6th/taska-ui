# mock | rest | hybrid (default: auth/issues -> gateway, other API groups -> mock)
VITE_TASKA_API_MODE=hybrid
# Dev: keep /api/v1 (Vite proxies it to the gateway, see VITE_TASKA_API_PROXY_TARGET).
# Prod on taska.ozero.dev: set https://api.taska.ozero.dev/api/v1
VITE_TASKA_API_BASE_URL=/api/v1
VITE_TASKA_API_PROXY_TARGET=https://api.taska.ozero.dev
VITE_BASE_PATH=/
VITE_ROUTER_MODE=browser
VITE_SITE_URL=http://localhost:5173/
